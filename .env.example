# NEXUS Backend Configuration — copy to .env and fill in real values.
# NEVER put real credentials in this file: it is committed to the repository.
NODE_ENV=development
PORT=3000

# MongoDB (Atlas)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net/?appName=Cluster0

# Firebase Admin (mobile push notifications — optional for the web demo)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# AI — Gemini (worker agents) + Claude (Validation cross-framework agent)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Security — REQUIRED in production (server refuses to boot without it)
# Generate: openssl rand -base64 32
JWT_SECRET=

# Operator authorization — protects approve/veto + operator routes.
# Set both to the same random value before hosting publicly.
OPERATOR_API_KEY=
VITE_OPERATOR_KEY=

# Band platform (credentials from hackathon kickoff)
# BAND_USE_SDK=true switches from MockBandAdapter to BandSdkAdapter
BAND_USE_SDK=false
BAND_API_URL=
BAND_API_KEY=

# Google Maps (web dashboard maps) — restrict the key by HTTP referrer!
# console.cloud.google.com → APIs & Services → Credentials → Create API Key
VITE_GOOGLE_MAPS_API_KEY=

# Optional DNS servers when local DNS can't resolve Atlas SRV hostnames
# Example: DNS_SERVERS=8.8.8.8,1.1.1.1
DNS_SERVERS=

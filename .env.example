# Maestro Backend Configuration — copy to .env and fill in real values.
# NEVER put real credentials in this file: it is committed to the repository.
NODE_ENV=development
PORT=3000

# MongoDB (Atlas)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net/?appName=Cluster0

# Firebase Admin (mobile push notifications — optional for the web demo)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# AI — Gemini (worker agents) + Claude (Validation cross-framework agent)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Cross-framework partner providers (hackathon credits; agents fall back to
# Gemini when unset). Both are OpenAI-compatible chat-completions APIs.
# PRIMARY_LLM=aiml routes ALL agents through AI/ML API first (Gemini becomes
# the fallback). Leave unset to keep Gemini primary with AI/ML API as fallback.
PRIMARY_LLM=
AIML_API_KEY=
AIML_API_MODEL=gpt-4o-mini
FEATHERLESS_API_KEY=
FEATHERLESS_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct

# Security — REQUIRED in production (server refuses to boot without it)
# Generate: openssl rand -base64 32
JWT_SECRET=

# Operator authorization — protects approve/veto + operator routes.
# Set both to the same random value before hosting publicly.
OPERATOR_API_KEY=
VITE_OPERATOR_KEY=

# Band platform — real Agent API (https://app.band.ai/api/v1/agent).
# Register TWO external agents at app.band.ai/agents (Band rejects self-mentions,
# so one agent posts and must @mention the other). BAND_USE_SDK=true activates
# the real BandSdkAdapter; leave false for the in-process MockBandAdapter.
# BAND_API_KEY    = posting agent's X-API-Key (shown once at creation)
# BAND_MENTION_ID = the OTHER agent's UUID (added as a participant + @mentioned)
# BAND_HUMAN_ID   = (optional) your human user UUID, added so you see each chat
BAND_USE_SDK=false
BAND_API_URL=https://app.band.ai/api/v1/agent
# Commander identity (primary, required): posts proposals/approval_requests
BAND_API_KEY=
BAND_API_AGENT_ID=
# Worker identities (optional): register more agents so DISTINCT agents appear
# collaborating in the Band chat. Each falls back to the commander when unset.
BAND_INTEL_KEY=
BAND_INTEL_ID=
BAND_RESPONSE_KEY=
BAND_RESPONSE_ID=
# Human owner UUID (added to every chat; the only approver unless the flag below is on)
BAND_HUMAN_ID=
BAND_MENTION_ID=
# DANGER: keep false for real human-in-the-loop. true lets a peer agent approve.
BAND_ALLOW_AGENT_APPROVAL=false

# Google Maps (web dashboard maps) — restrict the key by HTTP referrer!
# console.cloud.google.com → APIs & Services → Credentials → Create API Key
VITE_GOOGLE_MAPS_API_KEY=

# CORS allowlist for public hosting (comma-separated origins; unset = open)
# Example: CORS_ORIGIN=https://maestro-demo.example.com
CORS_ORIGIN=

# Set SEED_DEMO=true to allow demo-data seeding in production (off by default)
SEED_DEMO=

# Set LIVE_DATA_POLLING=true to ingest real GDACS/USGS/Open-Meteo events
# (each event runs the full LLM pipeline — keep off during demos)
LIVE_DATA_POLLING=

# Optional DNS servers when local DNS can't resolve Atlas SRV hostnames
# Example: DNS_SERVERS=8.8.8.8,1.1.1.1
DNS_SERVERS=

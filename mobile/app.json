{
  "expo": {
    "name": "Maestro",
    "slug": "maestro-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#121214"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.maestro.crisisplatform",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Maestro uses your location to send you alerts for incidents in your area.",
        "NSLocationAlwaysUsageDescription": "Maestro uses your location to send you alerts even when the app is in the background.",
        "NSMicrophoneUsageDescription": "Maestro uses your microphone to record voice incident reports."
      },
      "config": {
        "googleMapsApiKey": "YOUR_GOOGLE_MAPS_API_KEY"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0c10"
      },
      "package": "com.maestro.crisisplatform",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECORD_AUDIO",
        "POST_NOTIFICATIONS",
        "VIBRATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "edgeToEdgeEnabled": true,
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_GOOGLE_MAPS_API_KEY"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-location",
      "expo-notifications",
      [
        "expo-av",
        {
          "microphonePermission": "Maestro needs microphone access for voice incident reports."
        }
      ]
    ],
    "updates": {
      "enabled": false
    },
    "extra": {
      "eas": {
        "projectId": "d530f0f1-b79d-45d7-bb40-26d6dc391dc8"
      }
    },
    "owner": "hadiaishtiaq"
  }
}
